      "id": "resource",
      "label": "Resource",
      "type": "resource"
    },
    {
      "id": "ps",
      "label": "Person Server",
      "type": "person-server"
    },
    {
      "id": "as",
      "label": "Access Server",
      "type": "access-server"
    }
  ],
  "mission_blob": {
