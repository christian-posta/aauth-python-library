{
  "id": "missions-end-to-end",
  "title": "Full Mission Lifecycle (End-to-End)",
  "description": "The complete mission lifecycle: PS metadata discovery \u2192 mission proposal \u2192 approval \u2192 proactive authorization \u2192 PS-AS federation \u2192 resource access. The s256 mission fingerprint flows through every token and header.",
  "spec_section": "\u00a7 Mission Lifecycle",
  "category": "missions",
  "demo_phase": 12,
  "participants": [
    {
      "id": "agent",
      "label": "Agent",
      "type": "agent"
    },
    {
      "id": "resource",
      "label": "Resource",
      "type": "resource"
    },
    {
      "id": "ps",
      "label": "Person Server",
      "type": "person-server"
    },
    {
      "id": "as",
      "label": "Access Server",
      "type": "access-server"
    }
  ],
  "steps": [
    {
      "step": 1,
      "from": "agent",
      "to": "ps",
      "label": "Discover PS metadata",
      "method": "GET",
      "url": "https://ps.example/.well-known/aauth-person.json",
      "request_headers": {
        "Host": "ps.example"
      },
      "request_body": null,
      "response_status": 200,
      "response_headers": {
        "Content-Type": "application/json"
      },
      "response_body": {
        "person_server": "https://ps.example",
        "token_endpoint": "https://ps.example/token",
        "mission_endpoint": "https://ps.example/mission",
        "jwks_uri": "https://ps.example/jwks.json"
      },
      "tokens": [],
      "signature": null,
      "annotations": [
        "Agent discovers mission_endpoint and token_endpoint from PS well-known metadata."
      ],
      "is_response": false
    },
    {
      "step": 2,
      "from": "agent",
      "to": "ps",
      "label": "POST mission proposal \u2192 approved + s256",
      "method": "POST",
      "url": "https://ps.example/mission",
      "request_headers": {
        "Content-Type": "application/json",
        "Signature-Key": "sig=jwks_uri;id=\"https://agent.example\";kid=\"agent-key-1\"",
        "Signature-Input": "sig=(\"@method\" \"@authority\" \"@path\" \"signature-key\");created=1700000000;alg=\"ed25519\"",
        "Signature": "sig=:PDw8PDw8PDw8PDw8PDw8PDw8PDw8PDw8PDw8PDw8PDw8PDw8PDw8PDw8PDw8PDw8PDw8PDw8PDw8PDw8PDw8PA:"
      },
      "request_body": {
        "description": "# Analyze Q2 Customer Feedback\n\nRead customer feedback records and produce a summary report with sentiment analysis and key themes.",
        "tools": [
          {
            "name": "FeedbackReader",
            "description": "Read customer feedback records"
          },
          {
            "name": "ReportWriter",
            "description": "Write the summary report to the shared drive"
          }
        ]
      },
      "response_status": 200,
      "response_headers": {
        "Content-Type": "application/json",
        "AAuth-Mission": "approver=\"https://ps.example\"; s256=\"R9kNpXeErMQ1Jvk_vxYUp3YEdggmvUhksWtjXtcmnh0\""
      },
      "response_body": {
        "description": "# Analyze Q2 Customer Feedback\n\nRead customer feedback records and produce a summary report with sentiment analysis and key themes.",
