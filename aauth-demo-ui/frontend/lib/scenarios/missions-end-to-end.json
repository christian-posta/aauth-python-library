{
  "id": "missions-end-to-end",
  "title": "Full Mission Lifecycle (End-to-End)",
  "description": "The complete mission lifecycle, from PS discovery to resource access. Critically, mission approval requires user interaction — the PS returns 202 with an interaction URL so the user can review and approve the mission description and tools. Once approved, the s256 mission fingerprint flows unchanged through every token and header: proposal → AAuth-Mission → resource token → auth token → final access check.",
  "spec_section": "§ Mission Lifecycle",
  "category": "missions",
