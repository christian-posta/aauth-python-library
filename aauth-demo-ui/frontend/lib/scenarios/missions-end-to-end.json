      "tokens": [],
      "signature": null,
      "annotations": [
        "PS approves mission. s256 = SHA-256(blob) = R9kNpXeErMQ1Jvk_vxYUp3YE\u2026",
        "Agent stores approver URL + s256 for all subsequent requests."
      ],
      "is_response": false
    },
