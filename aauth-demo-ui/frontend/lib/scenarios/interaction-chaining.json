    {
      "step": 7,
      "from": "agent",
      "to": "r1",
      "label": "Agent polls R1 \u2192 200 final result",
      "method": "GET",
      "url": "https://api.example/pending/r1_chain_9a2f",
      "request_headers": {
        "Signature-Key": "sig=jwks_uri;id=\"https://agent.example\";kid=\"agent-key-1\"",
        "Signature-Input": "sig=(\"@method\" \"@authority\" \"@path\" \"signature-key\");created=1700000000;alg=\"ed25519\"",
        "Signature": "sig=:Z2dnZ2dnZ2dnZ2dnZ2dnZ2dnZ2dnZ2dnZ2dnZ2dnZ2dnZ2dnZ2dnZ2dnZ2dnZ2dnZ2dnZ2dnZ2dnZ2dnZ2dnZw:"
