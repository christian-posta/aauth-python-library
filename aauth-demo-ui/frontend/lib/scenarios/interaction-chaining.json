        "Signature": "sig=:ZGRkZGRkZGRkZGRkZGRkZGRkZGRkZGRkZGRkZGRkZGRkZGRkZGRkZGRkZGRkZGRkZGRkZGRkZGRkZGRkZGRkZA:"
      },
      "request_body": null,
      "response_status": 202,
      "response_headers": {
        "Content-Type": "application/json"
      },
      "response_body": {
        "pending": "https://api.example/pending/r1_chain_9a2f",
        "interaction": "https://api.example/interact?code=r1_chain_9a2f"
      },
      "tokens": [
        {
          "name": "Auth Token (Agent\u2192R1)",
          "typ": "aa-auth+jwt",
          "raw": "eyJhbGciOiJFZERTQSIsImtpZCI6ImFzMS1rZXktMSIsInR5cCI6ImFhLWF1dGgrand0In0..jgOiLDIGo4TiSjiL9tEIvkFIR4qX6r7GytzA4MQRatCIHDPT9WimFNGrokkFR1RiUmM0EaoZwx254O2Or6LpBQ",
          "header": {
            "alg": "EdDSA",
            "kid": "as1-key-1",
            "typ": "aa-auth+jwt"
          },
          "payload": {
            "iss": "https://as.example",
            "aud": "https://api.example",
            "dwk": "aauth-access.json",
            "jti": "34449e73-d2d2-4e45-80d2-01b4b198e025",
            "cnf": {
              "jwk": {
                "kty": "OKP",
                "crv": "Ed25519",
                "x": "J08ILBqisxm8GNLnW5txcl48zGsm6Ow2GiQAS0sLO1M",
                "kid": "agent-key-1"
              }
            },
            "iat": 1776222894,
            "exp": 1776226494,
            "agent": "aauth:agent-1@agent.example",
