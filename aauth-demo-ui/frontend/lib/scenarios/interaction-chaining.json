{
  "id": "interaction-chaining",
  "title": "Interaction Chaining (202 Bubbles Back)",
  "description": "R1 calls R2, but R2’s AS requires user consent. Instead of blocking, R1 returns its own 202 to the original agent, with an interaction URL that redirects through R1 to AS2. The agent polls R1; R1 polls AS2 in parallel. Once the user consents at AS2, R1 gets the auth token, completes the R2 call, and the agent’s next poll returns the combined result.",
  "spec_section": "§ Interaction Chaining",
  "category": "advanced",
  "demo_phase": 9,
  "participants": [
    {
      "id": "agent",
      "label": "Agent",
      "type": "agent"
    },
    {
      "id": "r1",
      "label": "Resource 1",
      "type": "resource"
    },
    {
      "id": "as1",
      "label": "Access Server 1",
      "type": "access-server"
    },
    {
      "id": "r2",
      "label": "Resource 2",
      "type": "resource"
    },
    {
      "id": "as2",
      "label": "Access Server 2",
      "type": "access-server"
    },
    {
      "id": "user",
      "label": "User",
      "type": "user"
    }
  ],
  "deferred_timeline": {
    "title": "Interaction Chain Timeline",
    "events": [
      {
        "step": 1,
        "status": 202,
        "label": "R1 bubbles 202 to agent",
        "detail": "R1 needs R2 consent — proxies the interaction URL back to the agent"
      },
      {
        "step": 3,
        "status": 202,
        "label": "AS2 requires user consent",
        "detail": "R1 submits R2 resource token to AS2; AS2 returns 202 + interaction URL"
      },
      {
        "step": 4,
        "status": 302,
        "label": "Agent’s interact URL → AS2",
        "detail": "User visits R1’s interact URL; R1 redirects to AS2’s consent page"
      },
      {
        "step": 5,
        "status": 200,
        "label": "User approves at AS2",
        "detail": "User consents to R1 accessing R2 on the agent’s behalf"
      },
      {
        "step": 6,
        "status": 200,
        "label": "R1 gets auth token from AS2",
        "detail": "R1 polls AS2 and receives chained auth token for R2"
      },
      {
        "step": 7,
        "status": 200,
        "label": "Agent gets final result",
        "detail": "Agent polls R1 and receives the combined result"
      }
    ]
  },
