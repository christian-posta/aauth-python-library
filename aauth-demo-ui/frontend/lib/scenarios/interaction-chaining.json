      "request_body": {
        "resource_token": "eyJhbGciOiJFZERTQSIsImtpZCI6ImFzMi1rZXktMSIsInR5cCI6ImFhLXJlc291cmNlK2p3dCJ9..Xt0E-YRp9tvXXT9mi7dX4xTcMbn7F1HCKJOZjD-CiRI3AJGzrGpgk7s09Ohep9uq-gOajX_n_N0D-6gN3bcmDw",
        "upstream_token": "eyJhbGciOiJFZERTQSIsImtpZCI6ImFzMS1rZXktMSIsInR5cCI6ImFhLWF1dGgrand0In0..jgOiLDIGo4TiSjiL9tEIvkFIR4qX6r7GytzA4MQRatCIHDPT9WimFNGrokkFR1RiUmM0EaoZwx254O2Or6LpBQ"
      },
      "response_status": 202,
      "response_headers": {
        "Content-Type": "application/json"
      },
      "response_body": {
        "pending": "http://resource1.example/pending/as2_interact_b3e1",
        "interaction": "http://resource1.example/interact?code=as2_interact_b3e1"
      },
      "tokens": [],
      "signature": null,
      "annotations": [
        "AS2 requires user consent for R1 to access R2.",
        "AS2 returns 202 + interaction URL (pointing to AS2 directly).",
        "R1 will poll AS2's pending URL while bubbling the 202 back to the agent."
      ],
      "is_response": false
    },
    {
      "step": 4,
      "from": "user",
      "to": "r1",
      "label": "User opens R1 /interact \u2192 redirected to AS2",
      "method": "GET",
      "url": "https://api.example/interact?code=r1_chain_9a2f",
      "request_headers": {
        "Cookie": "session=user123"
      },
      "request_body": null,
      "response_status": 302,
      "response_headers": {
        "Location": "http://resource1.example/interact?code=as2_interact_b3e1"
      },
      "response_body": null,
      "tokens": [],
      "signature": null,
      "annotations": [
        "User visits R1's /interact URL (from agent's 202 response).",
        "R1 redirects user to AS2's actual interaction page.",
        "This chaining is transparent to the user."
      ],
      "is_response": false
    },
    {
      "step": 5,
      "from": "user",
      "to": "as2",
      "label": "User approves at AS2 consent page",
      "method": "GET",
      "url": "http://resource1.example/interact?code=as2_interact_b3e1",
      "request_headers": {
        "Cookie": "session=user123"
      },
      "request_body": null,
      "response_status": 200,
      "response_headers": {
        "Content-Type": "text/html"
      },
      "response_body": "<!-- AS2 consent: R1 (acting as agent) \u2192 R2. User approves. -->",
      "tokens": [],
      "signature": null,
      "annotations": [
        "User approves R1's access to R2 at AS2's consent page."
      ],
      "is_response": false
    },
    {
      "step": 6,
      "from": "r1",
      "to": "as2",
      "label": "R1 polls AS2 \u2192 auth token for R2",
      "method": "GET",
      "url": "http://resource1.example/pending/as2_interact_b3e1",
      "request_headers": {
        "Signature-Key": "sig=jwks_uri;id=\"https://api.example\";kid=\"r1-key-1\"",
        "Signature-Input": "sig=(\"@method\" \"@authority\" \"@path\" \"signature-key\");created=1700000000;alg=\"ed25519\"",
