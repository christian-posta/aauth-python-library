      },
      "tokens": [
        {
          "name": "Auth Token (R1\u2192R2) \u2014 chained",
          "typ": "aa-auth+jwt",
          "raw": "eyJhbGciOiJFZERTQSIsImtpZCI6ImFzMi1rZXktMSIsInR5cCI6ImFhLWF1dGgrand0In0..z3W50MLc-WzSDtPyRXZIgYgdFgt_q3MIATrX2JxxP2fiGpLNA_00cyF8n2nggqgxwOb-BhbD2BkLtCEfsVSeBQ",
          "header": {
            "alg": "EdDSA",
            "kid": "as2-key-1",
            "typ": "aa-auth+jwt"
          },
          "payload": {
            "iss": "http://resource1.example",
            "aud": "https://ps.example",
            "dwk": "aauth-access.json",
            "jti": "60c21e1a-68cf-4bb1-8527-1a2c722300ab",
            "cnf": {
              "jwk": {
                "kty": "OKP",
                "crv": "Ed25519",
                "x": "yWKGvmTQl_Dk1yd1psaRL22d0Dfaqdvvx1LkgN4t0xM",
                "kid": "r1-key-1"
              }
            },
            "iat": 1776222894,
            "exp": 1776226494,
            "agent": "aauth:agent-2@agent.example",
            "act": {
