{
  "id": "call-chaining",
  "title": "Call Chaining (R1 acts as Agent to R2)",
  "description": "Resource 1 needs data from Resource 2 to fulfil the agent’s request. R1 acts as an agent to call R2 — sending the R2 resource token plus the upstream auth token to the PS. The resulting auth token has nested act claims recording the full delegation chain: R2 sees R1 as the current actor, acting on behalf of the original agent.",
  "spec_section": "§ Call Chaining",
  "category": "advanced",
  "demo_phase": 7,
  "participants": [
    {
      "id": "agent",
      "label": "Agent",
      "type": "agent"
    },
    {
      "id": "r1",
      "label": "Resource 1",
      "type": "resource"
    },
    {
      "id": "as1",
      "label": "Access Server 1",
      "type": "access-server"
    },
    {
      "id": "ps",
      "label": "Person Server",
      "type": "person-server"
    },
    {
      "id": "r2",
      "label": "Resource 2",
      "type": "resource"
    },
    {
      "id": "as2",
      "label": "Access Server 2",
      "type": "access-server"
    }
  ],
  "steps": [
    {
      "step": 1,
      "from": "agent",
      "to": "r1",
      "label": "Agent → R1 with AS1 auth token → R1 needs R2",
      "method": "GET",
      "url": "https://api.example/data",
      "Host": "api.example",
      "Signature-Key": "sig=jwt;jwt=\"eyJhbGciOiJFZERTQSIsImtpZCI6ImFzMS1rZXktMSIsInR5cCI6ImFhLWF1dGgrand0In0…\"",
      "Signature-Input": "sig=(\"@method\" \"@authority\" \"@path\" \"signature-key\");created=1700000000;alg=\"ed25519\"",
      "Signature": "sig=:UFBQUFBQUFBQUFBQUFBQUFBQUFBQUFBQUFBQUFBQUFBQUFBQUFBQUFBQUFBQUFBQUFBQUFBQUFBQUFBQUFBQ:",
      "request_headers": {
        "Host": "api.example",
        "Signature-Key": "sig=jwt;jwt=\"eyJhbGciOiJFZERTQSIsImtpZCI6ImFzMS1rZXktMSIsInR5cCI6ImFhLWF1dGgrand0In0…\"",
        "Signature-Input": "sig=(\"@method\" \"@authority\" \"@path\" \"signature-key\");created=1700000000;alg=\"ed25519\"",
        "Signature": "sig=:UFBQUFBQUFBQUFBQUFBQUFBQUFBQUFBQUFBQUFBQUFBQUFBQUFBQUFBQUFBQUFBQUFBQUFBQUFBQUFBQUFBQ:"
      },
      "request_body": null,
      "response_status": 200,
      "response_headers": {
        "Content-Type": "application/json"
      },
      "response_body": {
        "status": "processing",
        "note": "R1 needs data from R2 to fulfil your request"
      },
      "tokens": [
        {
          "name": "Auth Token (Agent→R1)",
          "typ": "aa-auth+jwt",
          "raw": "eyJhbGciOiJFZERTQSIsImtpZCI6ImFzMS1rZXktMSIsInR5cCI6ImFhLWF1dGgrand0In0…",
          "header": {
            "alg": "EdDSA",
            "kid": "as1-key-1",
            "typ": "aa-auth+jwt"
          },
          "payload": {
            "iss": "https://as.example",
            "aud": "https://api.example",
            "dwk": "aauth-access.json",
            "jti": "5aba3c5f-0509-4483-a99e-394c0a2b1313",
            "cnf": {
              "jwk": {
                "kty": "OKP",
                "crv": "Ed25519",
                "x": "T_1-DXNIxIv0tFEqrD9q4LHu4VcHJgsiDPN__R1_Y2U",
                "kid": "agent-key-1"
              }
            },
            "iat": 1776222894,
            "exp": 1776226494,
            "agent": "aauth:local@agent.example",
            "act": {
              "sub": "aauth:local@agent.example"
            },
            "scope": "read"
          },
          "signature_b64": "wuhpIWVGWe2kNxVtCXDsYgp0ngxD7Hth5TdEzOmRJhVf5-dln4mwpNw6DAhd1y1VfO-KqzSgN1PBwdvEe_wMDQ"
        }
      ],
      "signature": {
        "scheme": "jwt",
        "signature_base": "\"@method\": GET\n\"@authority\": api.example\n\"@path\": /data\n\"signature-key\": sig=jwt;jwt=\"eyJhbGciOiJFZERTQSIsImtpZCI6ImFzMS1rZXktMSIsInR5cCI6ImFhLWF1dGgrand0In0…\"\n\"@signature-params\": sig=(\"@method\" \"@authority\" \"@path\" \"signature-key\");created=1700000000;alg=\"ed25519\"",
        "signature_input": "sig=(\"@method\" \"@authority\" \"@path\" \"signature-key\");created=1700000000;alg=\"ed25519\"",
        "signature_key": "sig=jwt;jwt=\"eyJhbGciOiJFZERTQSIsImtpZCI6ImFzMS1rZXktMSIsInR5cCI6ImFhLWF1dGgrand0In0…\"",
        "covered_components": [
          "@method",
          "@authority",
          "@path",
          "signature-key"
        ]
      },
      "annotations": [
        "Agent accesses R1 using its AS1-issued auth token (sig=jwt — auth token is the signing credential).",
        "R1 processes the request but needs data from R2 to fulfil it.",
        "R1 returns 200 immediately (processing); it will call R2 while the agent waits."
      ],
      "is_response": false
    },
    {
      "step": 2,
      "from": "r1",
      "to": "r2",
      "label": "R1 calls R2 → 401 + R2 resource token",
      "method": "GET",
      "url": "https://resource2.example/data",
      "request_headers": {
        "Host": "resource2.example",
        "Signature-Key": "sig=jwks_uri;id=\"https://api.example\";kid=\"r1-key-1\";dwk=\"aauth-resource.json\"",
        "Signature-Input": "sig=(\"@method\" \"@authority\" \"@path\" \"signature-key\");created=1700000000;alg=\"ed25519\"",
        "Signature": "sig=:UVFRUVFRUVFRUVFRUVFRUVFRUVFRUVFRUVFRUVFRUVFRUVFRUVFRUVFRUVFRUVFRUVFRUVFRUVFRUVFRUVFR:"
      },
      "request_body": null,
      "response_status": 401,
      "response_headers": {
        "AAuth-Requirement": "requirement=auth_token; resource_token=\"eyJhbGciOiJFZERTQSIsImtpZCI6InIyLWtleS0xIiwidHlwIjoiYWEtcmVzb3VyY2Urand0In0…\""
      },
      "response_body": {
        "error": "auth_token_required"
      },
      "tokens": [
        {
          "name": "R2 Resource Token",
          "typ": "aa-resource+jwt",
          "raw": "eyJhbGciOiJFZERTQSIsImtpZCI6InIyLWtleS0xIiwidHlwIjoiYWEtcmVzb3VyY2Urand0In0…",
          "header": {
            "alg": "EdDSA",
            "kid": "r2-key-1",
            "typ": "aa-resource+jwt"
          },
          "payload": {
            "iss": "https://resource2.example",
            "aud": "https://ps.example",
            "dwk": "aauth-resource.json",
            "jti": "beb2080d-282d-4a0f-abe1-d3b10bb0a456",
            "agent": "aauth:local@api.example",
            "agent_jkt": "tiHsh56qeqmWa0mJdFUhRj-2o-gOmZgvS3AGauqQeOE",
            "scope": "read",
            "iat": 1776222894,
            "exp": 1776223494
          },
          "signature_b64": "XU8gSxwTjeDFPFoV_gMvpPxxzzJB7uh6YgaeJdV65SL_lPmmjjDMRpvPha8CaiFAI1Ay6PKWcl7Bh9XycDmVAg"
        }
      ],
      "signature": null,
      "annotations": [
        "R1 signs with its own resource server identity (sig=jwks_uri) — R1 is a server, not an agent.",
        "R2 issues a resource token: agent=R1’s AAuth identifier, agent_jkt=R1’s key thumbprint.",
        "R2 resource token aud=PS because R1 will take it to the PS for federation."
      ],
      "is_response": false
    },
    {
      "step": 3,
      "from": "r1",
      "to": "ps",
      "label": "R1 sends R2 resource token + upstream auth token to PS",
      "method": "POST",
      "url": "https://ps.example/token",
      "request_headers": {
        "Content-Type": "application/json",
        "Signature-Key": "sig=jwks_uri;id=\"https://api.example\";kid=\"r1-key-1\";dwk=\"aauth-resource.json\"",
        "Signature-Input": "sig=(\"@method\" \"@authority\" \"@path\" \"signature-key\");created=1700000000;alg=\"ed25519\"",
        "Signature": "sig=:UlJSUlJSUlJSUlJSUlJSUlJSUlJSUlJSUlJSUlJSUlJSUlJSUlJSUlJSUlJSUlJSUlJSUlJSUlJSUlJSUlJS:"
      },
      "request_body": {
        "resource_token": "eyJhbGciOiJFZERTQSIsImtpZCI6InIyLWtleS0xIiwidHlwIjoiYWEtcmVzb3VyY2Urand0In0…",
        "upstream_token": "eyJhbGciOiJFZERTQSIsImtpZCI6ImFzMS1rZXktMSIsInR5cCI6ImFhLWF1dGgrand0In0…"
      },
      "response_status": 200,
      "response_headers": {
        "Content-Type": "application/json"
      },
      "response_body": {
        "auth_token": "eyJhbGciOiJFZERTQSIsImtpZCI6ImFzMi1rZXktMSIsInR5cCI6ImFhLWF1dGgrand0In0…",
        "expires_in": 3600
      },
      "tokens": [
        {
          "name": "R2 Resource Token",
          "typ": "aa-resource+jwt",
          "raw": "eyJhbGciOiJFZERTQSIsImtpZCI6InIyLWtleS0xIiwidHlwIjoiYWEtcmVzb3VyY2Urand0In0…",
          "header": {
            "alg": "EdDSA",
            "kid": "r2-key-1",
            "typ": "aa-resource+jwt"
          },
          "payload": {
            "iss": "https://resource2.example",
            "aud": "https://ps.example",
            "dwk": "aauth-resource.json",
            "jti": "beb2080d-282d-4a0f-abe1-d3b10bb0a456",
            "agent": "aauth:local@api.example",
            "agent_jkt": "tiHsh56qeqmWa0mJdFUhRj-2o-gOmZgvS3AGauqQeOE",
            "scope": "read",
            "iat": 1776222894,
            "exp": 1776223494
          },
          "signature_b64": "XU8gSxwTjeDFPFoV_gMvpPxxzzJB7uh6YgaeJdV65SL_lPmmjjDMRpvPha8CaiFAI1Ay6PKWcl7Bh9XycDmVAg"
        },
        {
          "name": "Auth Token (Agent→R1)",
          "typ": "aa-auth+jwt",
          "raw": "eyJhbGciOiJFZERTQSIsImtpZCI6ImFzMS1rZXktMSIsInR5cCI6ImFhLWF1dGgrand0In0…",
          "header": {
            "alg": "EdDSA",
            "kid": "as1-key-1",
            "typ": "aa-auth+jwt"
          },
          "payload": {
            "iss": "https://as.example",
            "aud": "https://api.example",
            "dwk": "aauth-access.json",
            "jti": "5aba3c5f-0509-4483-a99e-394c0a2b1313",
            "cnf": {
              "jwk": {
                "kty": "OKP",
                "crv": "Ed25519",
                "x": "T_1-DXNIxIv0tFEqrD9q4LHu4VcHJgsiDPN__R1_Y2U",
                "kid": "agent-key-1"
              }
            },
            "iat": 1776222894,
            "exp": 1776226494,
            "agent": "aauth:local@agent.example",
            "act": {
              "sub": "aauth:local@agent.example"
            },
            "scope": "read"
          },
          "signature_b64": "wuhpIWVGWe2kNxVtCXDsYgp0ngxD7Hth5TdEzOmRJhVf5-dln4mwpNw6DAhd1y1VfO-KqzSgN1PBwdvEe_wMDQ"
        },
        {
          "name": "Auth Token (R1→R2)",
          "typ": "aa-auth+jwt",
          "raw": "eyJhbGciOiJFZERTQSIsImtpZCI6ImFzMi1rZXktMSIsInR5cCI6ImFhLWF1dGgrand0In0…",
          "header": {
            "alg": "EdDSA",
            "kid": "as2-key-1",
            "typ": "aa-auth+jwt"
          },
          "payload": {
            "iss": "https://as2.example",
            "aud": "https://resource2.example",
            "dwk": "aauth-access.json",
            "jti": "3d65ef65-a9d6-4be4-861b-eba7a768ad31",
            "cnf": {
              "jwk": {
                "kty": "OKP",
                "crv": "Ed25519",
                "x": "TcPUiIAqBW7mCyUb6bxTRzoKPtRYGGP2xF4yBR5sz20",
                "kid": "r1-key-1"
              }
            },
            "iat": 1776222894,
            "exp": 1776226494,
            "agent": "aauth:local@api.example",
            "act": {
              "sub": "aauth:local@agent.example"
            },
            "scope": "read"
          },
          "signature_b64": "VcuDxql8SIBZOQ51zMDamtvBrTttCCqGlQRbgsIMiBJGWx4WBhoH3rizEV6Qj0Jx3MuAVzjxK1-gKc_hJUrdCw"
        }
      ],
      "signature": null,
      "annotations": [
        "R1 sends both: the R2 resource token AND the upstream auth token (proving the original agent’s delegation).",
        "PS evaluates the chain: original agent → delegated to R1 → R1 needs R2.",
        "PS federates to AS2 with full chain context; AS2 mints a chained auth token.",
        "Auth token act claim: {sub: ‘aauth:local@agent.example’} — original agent is the delegating principal."
      ],
      "is_response": false
    },
    {
      "step": 4,
      "from": "r1",
      "to": "r2",
      "label": "R1 accesses R2 with chained auth token (sig=jwt)",
      "method": "GET",
      "url": "https://resource2.example/data",
      "request_headers": {
        "Signature-Key": "sig=jwt;jwt=\"eyJhbGciOiJFZERTQSIsImtpZCI6ImFzMi1rZXktMSIsInR5cCI6ImFhLWF1dGgrand0In0…\"",
        "Signature-Input": "sig=(\"@method\" \"@authority\" \"@path\" \"signature-key\");created=1700000000;alg=\"ed25519\"",
        "Signature": "sig=:U1NTU1NTU1NTU1NTU1NTU1NTU1NTU1NTU1NTU1NTU1NTU1NTU1NTU1NTU1NTU1NTU1NTU1NTU1NTU1NTU1NT:"
      },
      "request_body": null,
      "response_status": 200,
      "response_headers": {
        "Content-Type": "application/json"
      },
      "response_body": {
