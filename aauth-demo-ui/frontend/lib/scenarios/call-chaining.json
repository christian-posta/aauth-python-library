        }
      ],
      "signature": {
        "scheme": "jwt",
        "signature_base": "\"@method\": GET\n\"@authority\": resource2.example\n\"@path\": /data\n\"signature-key\": sig=jwt;jwt=\"eyJhbGciOiJFZERTQSIsImtpZCI6ImFzMi1rZXktMSIsInR5cCI6ImFhLWF1dGgrand0In0…\"\n\"@signature-params\": sig=(\"@method\" \"@authority\" \"@path\" \"signature-key\");created=1700000000;alg=\"ed25519\"",
        "signature_input": "sig=(\"@method\" \"@authority\" \"@path\" \"signature-key\");created=1700000000;alg=\"ed25519\"",
        "signature_key": "sig=jwt;jwt=\"eyJhbGciOiJFZERTQSIsImtpZCI6ImFzMi1rZXktMSIsInR5cCI6ImFhLWF1dGgrand0In0…\"",
        "covered_components": [
          "@method",
          "@authority",
          "@path",
          "signature-key"
        ]
      },
      "annotations": [
        "R1 presents the chained auth token via sig=jwt — the auth token IS the signing credential.",
        "R2 verifies: agent=aauth:local@api.example (R1), act.sub=aauth:local@agent.example (original agent).",
        "Full delegation chain is cryptographically verifiable."
      ],
      "is_response": false
    },
    {
      "step": 5,
      "from": "r1",
      "to": "agent",
      "label": "R1 returns combined result to agent",
      "method": "GET",
      "url": "(response to original request)",
      "request_headers": {},
      "request_body": null,
      "response_status": 200,
      "response_headers": {
        "Content-Type": "application/json"
      },
      "response_body": {
        "result": "Combined data from R1 + R2",
        "chain_verified": true
      },
      "tokens": [],
      "signature": null,
      "annotations": [
        "R1 combines its own data with R2’s data and returns the result to the original agent."
      ],
      "is_response": true
    }
