            "agent_jkt": "tiHsh56qeqmWa0mJdFUhRj-2o-gOmZgvS3AGauqQeOE",
            "scope": "read",
            "iat": 1776222894,
            "exp": 1776223494
          },
          "signature_b64": "XU8gSxwTjeDFPFoV_gMvpPxxzzJB7uh6YgaeJdV65SL_lPmmjjDMRpvPha8CaiFAI1Ay6PKWcl7Bh9XycDmVAg"
