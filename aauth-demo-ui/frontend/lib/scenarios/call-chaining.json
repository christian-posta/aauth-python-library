            "alg": "EdDSA",
            "kid": "as1-key-1",
            "typ": "aa-auth+jwt"
          },
          "payload": {
            "iss": "https://as.example",
            "aud": "https://api.example",
            "dwk": "aauth-access.json",
            "jti": "5aba3c5f-0509-4483-a99e-394c0a2b1313",
            "cnf": {
              "jwk": {
                "kty": "OKP",
                "crv": "Ed25519",
                "x": "3uEVe1sh5o_MWofYyVsr4WPtrFtfZ2_pW1auy9WA3YM",
                "kid": "agent-key-1"
              }
            },
            "iat": 1776222894,
            "exp": 1776226494,
            "agent": "aauth:agent-1@agent.example",
            "scope": "read"
