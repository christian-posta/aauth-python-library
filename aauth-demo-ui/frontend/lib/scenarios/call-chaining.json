        "agent_chain": "aauth:local@api.example acting on behalf of aauth:local@agent.example"
      },
      "tokens": [
        {
          "name": "Auth Token (R1→R2) — with nested act",
          "typ": "aa-auth+jwt",
          "raw": "eyJhbGciOiJFZERTQSIsImtpZCI6ImFzMi1rZXktMSIsInR5cCI6ImFhLWF1dGgrand0In0…",
