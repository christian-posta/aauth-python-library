          "name": "Auth Token (Agent\u2192R1)",
          "typ": "aa-auth+jwt",
          "raw": "eyJhbGciOiJFZERTQSIsImtpZCI6ImFzMS1rZXktMSIsInR5cCI6ImFhLWF1dGgrand0In0..wuhpIWVGWe2kNxVtCXDsYgp0ngxD7Hth5TdEzOmRJhVf5-dln4mwpNw6DAhd1y1VfO-KqzSgN1PBwdvEe_wMDQ",
