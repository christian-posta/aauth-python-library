{
  "id": "call-chaining",
  "title": "Call Chaining (R1 acts as Agent to R2)",
  "description": "Resource 1 needs data from Resource 2 to fulfil the agent's request. R1 acts as an agent to call R2 \u2014 sending the R2 resource token + upstream auth token to the PS. The resulting auth token has nested act claims recording the full delegation chain.",
  "spec_section": "\u00a7 Call Chaining",
  "category": "advanced",
  "demo_phase": 7,
  "participants": [
    {
      "id": "agent",
      "label": "Agent",
      "type": "agent"
    },
    {
      "id": "r1",
      "label": "Resource 1",
      "type": "resource"
    },
    {
      "id": "as1",
      "label": "Access Server 1",
      "type": "access-server"
    },
    {
      "id": "ps",
      "label": "Person Server",
      "type": "person-server"
    },
    {
      "id": "r2",
      "label": "Resource 2",
      "type": "resource"
    },
    {
      "id": "as2",
      "label": "Access Server 2",
      "type": "access-server"
    }
  ],
  "steps": [
