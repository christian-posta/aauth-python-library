      "response_headers": {
        "Content-Type": "application/json",
        "AAuth-Access": "rm-tok-a8f3c2e1b94d7065f2a1"
      },
      "response_body": {
        "message": "Access granted!",
        "agent": "aauth:local@agent.example"
      },
      "tokens": [
        {
          "name": "Agent Token",
          "typ": "aa-agent+jwt",
