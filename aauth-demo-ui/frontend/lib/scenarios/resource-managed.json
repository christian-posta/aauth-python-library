          "status": 202,
          "label": "Interaction required",
          "detail": "Resource returns pending URL and interaction URL backed by its OIDC provider."
        },
        {
          "step": 2,
          "status": 202,
          "label": "Polling \u2014 not yet approved",
          "detail": "User has not completed login. Agent keeps polling."
        },
        {
          "step": 4,
          "status": 200,
          "label": "Approved",
          "detail": "User authenticated via OIDC. Resource issues opaque token."
        }
      ]
    },
