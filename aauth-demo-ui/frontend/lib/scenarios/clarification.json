{
  "id": "clarification",
  "title": "Clarification Chat During Consent",
  "description": "During authorization, the Access Server poses a clarification question to the agent before presenting the consent UI to the user. The agent declares clarification support via AAuth-Capabilities: clarification. The AS returns 202 with AAuth-Requirement: requirement=clarification so the agent can answer. Once answered, the AS proceeds to user consent. The user sees the agent’s clarification answer as part of the consent context.",
  "spec_section": "§ Clarification",
  "category": "advanced",
  "demo_phase": 8,
  "participants": [
    {
      "id": "agent",
      "label": "Agent",
      "type": "agent"
    },
    {
      "id": "resource",
      "label": "Resource",
      "type": "resource"
    },
    {
      "id": "as",
      "label": "Access Server",
      "type": "access-server"
    },
    {
      "id": "user",
      "label": "User",
      "type": "user"
    }
  ],
  "deferred_timeline": {
    "title": "Clarification & Consent Timeline",
    "events": [
      {
        "step": 2,
        "status": 202,
        "label": "Clarification required",
        "detail": "AS poses a question before showing consent UI to the user"
      },
      {
        "step": 3,
        "status": 202,
        "label": "Clarification answered",
        "detail": "Agent answers; AS now needs user consent with richer context"
      },
      {
        "step": 4,
        "status": 200,
        "label": "User approves with context",
        "detail": "User sees agent identity, scope, and clarification Q&A in consent UI"
      },
      {
        "step": 5,
        "status": 200,
        "label": "Auth token issued",
        "detail": "Agent polls and receives auth token after user approval"
      }
    ]
  },
  "steps": [
